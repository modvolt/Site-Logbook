auto-install-peers=false
strict-peer-dependencies=false

# Resilience against a slow/flaky npm registry during Docker builds (e.g. on the
# Hetzner host where registry requests have occasionally taken 20-30s each and
# stalled the whole deploy). Retry more, and wait longer before giving up.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
