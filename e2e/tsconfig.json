{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "baseUrl": "."
  },
  "include": [
    "tests/**/*.ts",
    "mock-tests/**/*.ts",
    "playwright.config.ts",
    "playwright.permissions.config.ts"
  ]
}
