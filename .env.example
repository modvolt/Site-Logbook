# ============================================================================
# Stavba deployment configuration
# ----------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) and fill in real secrets before
# running `docker compose up`. On Coolify, set these in the resource's
# environment UI instead of committing a .env file.
# ============================================================================

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=stavba
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=stavba

# --- API server -------------------------------------------------------------
# Secret used to sign session cookies. Generate one, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=change-me-session-secret-please

# Max request body size, in MB, for JSON / form payloads (default 50). This is
# the cap for CSV bulk imports and base64 uploads. If you raise it above 100,
# also raise client_max_body_size in artifacts/stavba/nginx.conf. Binary
# photo/document uploads have a separate, higher cap and are not affected.
MAX_REQUEST_BODY_MB=50

# --- Object storage (MinIO in Compose; any S3-compatible store in prod) ------
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY are the SINGLE credential pair used by
# both the API and the bundled MinIO. (MinIO requires the secret to be >= 8 chars.)
S3_ACCESS_KEY_ID=stavba-minio
S3_SECRET_ACCESS_KEY=change-me-minio-secret
S3_BUCKET=stavba
S3_REGION=us-east-1

# Host ports MinIO is published on (admin console + direct bucket access only).
# Uploads are proxied through the API, so the browser never connects to MinIO
# directly — no browser-reachable storage endpoint or bucket CORS is needed.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Use an EXTERNAL S3-compatible store instead of the bundled MinIO --------
# Leave S3_ENDPOINT UNSET to use the bundled MinIO (the API then uses
# http://minio:9000 with the credentials above). To store files in an external
# provider (Hetzner Object Storage, AWS S3, …) set S3_ACCESS_KEY_ID /
# S3_SECRET_ACCESS_KEY to the PROVIDER's keys (they replace the MinIO creds) and:
#   - S3_ENDPOINT to the provider endpoint (the bucket must already exist there)
#   - S3_REGION / S3_FORCE_PATH_STYLE as required by the provider
# The bundled minio/createbuckets services can then be left running (unused) or
# removed from docker-compose.yml. Example for Hetzner (Falkenstein):
# S3_ENDPOINT=https://fsn1.your-objectstorage.com
# S3_REGION=fsn1
# S3_FORCE_PATH_STYLE=true

# --- Web frontend -----------------------------------------------------------
# Host port the app is served on.
WEB_PORT=8080

# --- Database backups — optional but strongly recommended -------------------
# Automated pg_dump backups are uploaded to object storage (same bucket as
# uploads, under the "backups/" prefix). Backups are skipped automatically if
# object storage is not configured. Requires `pg_dump` (postgresql-client) on
# the API container — already included in artifacts/api-server/Dockerfile.
#
# Set to "false" to disable scheduled backups entirely (manual backups from the
# admin UI still work). Defaults to enabled when object storage is configured.
BACKUP_ENABLED=true
# How often the scheduled backup runs, in hours (default 24).
BACKUP_INTERVAL_HOURS=24
# How many of the most recent successful backups to keep; older ones are pruned
# from object storage and the backup log (default 14).
BACKUP_RETENTION=14
# Path to the pg_dump binary, if not on PATH (default: "pg_dump").
# PG_DUMP_PATH=/usr/bin/pg_dump

# --- Email (SMTP) — optional ------------------------------------------------
# Leave SMTP_HOST empty to disable outbound email (PDF job sheets).
SMTP_HOST=
SMTP_PORT=587
# "true" for implicit TLS (port 465); leave empty to auto-detect from the port.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- AI document extraction (OpenAI) — optional -----------------------------
# When configured AND enabled, uploaded cost-document PDFs/photos are extracted
# by OpenAI to PREFILL the header + lines. The AI result is NEVER auto-approved
# — it is saved as a "needs review" suggestion for an admin to confirm. The app
# works fully without OpenAI (documents are then routed to manual review).
#
# Self-hosted prod uses your OWN OpenAI API key (the Replit AI proxy is not
# available off-Replit). The key is read from the environment only; it is never
# stored in the database or logged. Leave OPENAI_API_KEY empty to disable.
OPENAI_API_KEY=
# Master switch — extraction only runs when this is exactly "true" (default off).
OPENAI_DOCUMENT_EXTRACTION_ENABLED=false
# Vision/file-capable model used for extraction (default "gpt-4o").
OPENAI_DOCUMENT_MODEL=gpt-4o
# Max input file size sent to OpenAI, in MB (default 32). OpenAI itself caps
# inputs (~32 MB per PDF, ~20 MB per image); going higher has no real effect.
OPENAI_MAX_FILE_MB=32
# Per-request timeout to OpenAI, in milliseconds (default 60000).
OPENAI_REQUEST_TIMEOUT_MS=60000

# --- Gmail / Google Workspace import — optional -----------------------------
# When fully configured, an admin can connect a Google account (read-only Gmail)
# and import supplier cost-document attachments (PDFs/photos) straight into
# Fakturace as "needs review" documents. The feature is OFF by default and the
# app works fully without it (documents can always be uploaded manually).
#
# Create an OAuth 2.0 "Web application" client in Google Cloud Console, enable
# the Gmail API, and set the authorized redirect URI to GOOGLE_REDIRECT_URI
# below (it must point at /api/billing/email-import/callback on your domain).
# Leave GOOGLE_CLIENT_ID empty to disable the feature entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL, e.g. https://your-domain.tld/api/billing/email-import/callback
GOOGLE_REDIRECT_URI=
# Encryption key for OAuth refresh tokens at rest (AES-256-GCM). REQUIRED for the
# Gmail import to work. Generate with: openssl rand -base64 32
# (accepts a 32-byte base64/hex value, or any passphrase which is hashed to 32B).
TOKEN_ENCRYPTION_KEY=

# Optional defaults applied when no labels are configured in the admin UI.
# Default Gmail label(s) to pull from (comma-separated). Empty = whole mailbox.
GMAIL_LABEL=
# Extra Gmail search query appended to the label filter (e.g. "has:attachment").
GMAIL_QUERY=
# Max messages fetched per sync (default 50).
GMAIL_MAX_MESSAGES=50
# "true" to label processed emails (Stavba/Importováno) so they aren't re-fetched.
GMAIL_LABEL_AFTER_IMPORT=false
