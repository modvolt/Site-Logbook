# ============================================================================
# Stavba deployment configuration
# ----------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) and fill in real secrets before
# running `docker compose up`. On Coolify, set these in the resource's
# environment UI instead of committing a .env file.
# ============================================================================

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=stavba
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=stavba

# --- API server -------------------------------------------------------------
# Secret used to sign session cookies. Generate one, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=change-me-session-secret-please

# --- Object storage (MinIO in Compose; any S3-compatible store in prod) ------
MINIO_ROOT_USER=stavba-minio
MINIO_ROOT_PASSWORD=change-me-minio-secret
S3_BUCKET=stavba
S3_REGION=us-east-1

# Host ports MinIO is published on (used by the browser for presigned uploads).
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Browser-reachable MinIO endpoint. The API itself uses the internal
# http://minio:9000 (set in docker-compose.yml); the browser uploads files
# directly to this URL, so it must resolve from the user's browser.
#   - Local Compose:  http://localhost:9000
#   - Coolify/prod:   https://storage.yourdomain.tld  (give MinIO its own
#                     subdomain via Coolify, or point at external S3)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# --- Web frontend -----------------------------------------------------------
# Host port the app is served on.
WEB_PORT=8080

# --- Email (SMTP) — optional ------------------------------------------------
# Leave SMTP_HOST empty to disable outbound email (PDF job sheets).
SMTP_HOST=
SMTP_PORT=587
# "true" for implicit TLS (port 465); leave empty to auto-detect from the port.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
