# ============================================================================
# Stavba deployment configuration
# ----------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) and fill in real secrets before
# running `docker compose up`. On Coolify, set these in the resource's
# environment UI instead of committing a .env file.
# ============================================================================

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=stavba
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=stavba

# --- API server -------------------------------------------------------------
# Secret used to sign session cookies. Generate one, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=change-me-session-secret-please

# --- Object storage (MinIO in Compose; any S3-compatible store in prod) ------
MINIO_ROOT_USER=stavba-minio
MINIO_ROOT_PASSWORD=change-me-minio-secret
S3_BUCKET=stavba
S3_REGION=us-east-1

# Host ports MinIO is published on (admin console + direct bucket access only).
# Uploads are proxied through the API, so the browser never connects to MinIO
# directly — no browser-reachable storage endpoint or bucket CORS is needed.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Web frontend -----------------------------------------------------------
# Host port the app is served on.
WEB_PORT=8080

# --- Database backups — optional but strongly recommended -------------------
# Automated pg_dump backups are uploaded to object storage (same bucket as
# uploads, under the "backups/" prefix). Backups are skipped automatically if
# object storage is not configured. Requires `pg_dump` (postgresql-client) on
# the API container — already included in artifacts/api-server/Dockerfile.
#
# Set to "false" to disable scheduled backups entirely (manual backups from the
# admin UI still work). Defaults to enabled when object storage is configured.
BACKUP_ENABLED=true
# How often the scheduled backup runs, in hours (default 24).
BACKUP_INTERVAL_HOURS=24
# How many of the most recent successful backups to keep; older ones are pruned
# from object storage and the backup log (default 14).
BACKUP_RETENTION=14
# Path to the pg_dump binary, if not on PATH (default: "pg_dump").
# PG_DUMP_PATH=/usr/bin/pg_dump

# --- Email (SMTP) — optional ------------------------------------------------
# Leave SMTP_HOST empty to disable outbound email (PDF job sheets).
SMTP_HOST=
SMTP_PORT=587
# "true" for implicit TLS (port 465); leave empty to auto-detect from the port.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
